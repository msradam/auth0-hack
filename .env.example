# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Chainlit OAuth (must match the above)
OAUTH_AUTH0_CLIENT_ID=your-client-id
OAUTH_AUTH0_CLIENT_SECRET=your-client-secret
OAUTH_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Custom API audience (must match Auth0 API configuration)
AUTH0_AUDIENCE_OVERRIDE=https://amanat.local/api

# LLM (llama-server with Granite 4 Micro)
OPENAI_API_BASE=http://localhost:8080/v1
OPENAI_API_KEY=llama

# Chainlit
CHAINLIT_AUTH_SECRET=generate-a-random-secret-here
